NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://fsa_user:fsa_password@postgres:5432/fsa_db
TEST_DATABASE_URL=postgresql://fsa_user:fsa_password@localhost:5432/fsa_test_db

POSTGRES_USER=fsa_user
POSTGRES_PASSWORD=fsa_password
POSTGRES_DB=fsa_db

REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=fsa-access-secret-super-secure-key-32chars!!
JWT_REFRESH_SECRET=fsa-refresh-secret-super-secure-key-32chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

EXPORTS_DIR=./exports
FRONTEND_URL=http://localhost:5173
